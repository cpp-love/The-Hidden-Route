{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "BuildAll",
            "description": "构建所有程序",
            "hidden": false,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER_LAUNCHER": {
                    "type": "STR",
                    "value": "ccache"
                },
                "CMAKE_CXX_COMPILER_LAUNCHER": {
                    "type": "STR",
                    "value": "ccache"
                },
                "CMAKE_BUILD_TYPE": {
                    "type": "STR",
                    "value": "DEBUG"
                },
                "CMAKE_EXPORT_COMPILE_COMMANDS": {
                    "type": "BOOL",
                    "value": "ON"
                },
                "THR_BUILD_HELPER": {
                    "type": "BOOL",
                    "value": "ON"
                },
                "THR_BUILD_TESTS": {
